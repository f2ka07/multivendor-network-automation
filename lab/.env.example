# Copy to lab/.env — the only file you edit each session (after one-time bootstrap).
# Repo: https://github.com/f2ka07/multivendor-network-automation
#
# One-time setup (you own this machine — WSL2 or your own EC2):
#   git clone https://github.com/f2ka07/multivendor-network-automation.git
#   cd multivendor-network-automation
#   bash lab/bootstrap.sh

# --- Lab backend ---
# devnet       = APIs to Cisco DevNet (no local containers)
# containerlab = deploy Nokia topology on YOUR machine (after bootstrap.sh)
LAB_MODE=devnet

# --- DevNet sandbox (from portal Quick Access — copy exactly, do not guess) ---
# 1. Open https://devnetsandbox.cisco.com/ (incognito if cookie/400 errors).
# 2. Catalog -> IOS XE Always-On (e.g. Catalyst 8000 or CSR Recommended).
# 3. Click Launch, pick a duration, wait until status is Active (~1-2 min).
# 4. Quick Access tab -> copy Host, Username, Password into the vars below.
# Reservation multi-node lab (VPN required): CAT8Kv at 10.10.20.48 often uses:
#   DEVNET_HOST=10.10.20.48
#   DEVNET_USER=developer
#   DEVNET_PASS=C1sco12345
# Check Instructions / Access Details in the portal if that fails.
# Credentials expire when the reservation ends — re-Launch and update lab/.env.
# Reservation labs use a jump host + high ports (from Quick Access / I/O tab):
#   Host: devnetsandbox-usw1-reservation.cisco.com
#   SSH port: 20384  (example — yours may differ)
#   RESTCONF port: check portal (often NOT 443 on reservation labs)
# Put hostname only in DEVNET_HOST — not host:port.
DEVNET_HOST=
DEVNET_USER=
DEVNET_PASS=
DEVNET_SSH_PORT=22
DEVNET_NETCONF_PORT=830
DEVNET_RESTCONF_PORT=443

# --- Containerlab (your self-hosted lab) ---
TOPOLOGY_FILE=lab/topology.clab.yml
INVENTORY_FILE=inventory/hosts.yaml

NOKIA_USER=admin
NOKIA_PASS=NokiaSrl1!
NOKIA_NODE=spine
NOKIA_GNMI_PORT=57400
# NOKIA_TLS_OVERRIDE=nokia-spine.multivendor-intro.io  # optional; cert CN from containerlab
# NOKIA_MGMT_HOST=   # optional override; otherwise read from inventory/hosts.yaml

CISCO_USER=admin
CISCO_PASS=admin

# --- NetBox (Module 7, optional, on your machine) ---
NETBOX_URL=http://127.0.0.1:8000
NETBOX_TOKEN=
