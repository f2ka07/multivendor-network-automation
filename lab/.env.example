# Copy to lab/.env and fill in values. This is the only file students edit for Track A.
# Course repository: https://github.com/f2ka07/multivendor-network-automation
# For Track B on a pre-built EC2 host, set LAB_MODE=containerlab (instructor default).

# --- Lab backend ---
# devnet       = scripts talk to Cisco DevNet sandbox (student laptop or EC2)
# containerlab = deploy topology on this host (pre-built EC2 only)
LAB_MODE=devnet

# --- DevNet sandbox (from portal Quick Access) ---
DEVNET_HOST=
DEVNET_USER=
DEVNET_PASS=

# Optional DevNet ports (defaults match most IOS XE sandboxes)
DEVNET_SSH_PORT=22
DEVNET_NETCONF_PORT=830
DEVNET_RESTCONF_PORT=443

# --- Containerlab (Track B; instructor usually sets these) ---
TOPOLOGY_FILE=lab/topology.clab.yml
INVENTORY_FILE=inventory/hosts.yaml

# Nokia SR Linux default lab creds (containerlab / SR Linux image)
NOKIA_USER=admin
NOKIA_PASS=NokiaSrl1!

# Cisco container creds (only if entitled IOL/XRd is in topology)
CISCO_USER=admin
CISCO_PASS=admin

# --- NetBox (Module 7) ---
NETBOX_URL=http://127.0.0.1:8000
NETBOX_TOKEN=

# --- Optional ---
# GITHUB_TOKEN=
