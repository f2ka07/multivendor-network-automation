# Copy to lab/.env — the only file you edit each session (after one-time bootstrap).
# Repo: https://github.com/f2ka07/multivendor-network-automation
#
# One-time setup (you own this machine — WSL2 or your own EC2):
#   git clone https://github.com/f2ka07/multivendor-network-automation.git
#   cd multivendor-network-automation
#   bash lab/bootstrap.sh

# --- Lab backend ---
# devnet       = APIs to Cisco DevNet (no local containers)
# containerlab = deploy Nokia topology on YOUR machine (after bootstrap.sh)
LAB_MODE=devnet

# --- DevNet sandbox (from portal Quick Access) ---
DEVNET_HOST=
DEVNET_USER=
DEVNET_PASS=

DEVNET_SSH_PORT=22
DEVNET_NETCONF_PORT=830
DEVNET_RESTCONF_PORT=443

# --- Containerlab (your self-hosted lab) ---
TOPOLOGY_FILE=lab/topology.clab.yml
INVENTORY_FILE=inventory/hosts.yaml

NOKIA_USER=admin
NOKIA_PASS=NokiaSrl1!

CISCO_USER=admin
CISCO_PASS=admin

# --- NetBox (Module 7, optional, on your machine) ---
NETBOX_URL=http://127.0.0.1:8000
NETBOX_TOKEN=
